--- !u!114 &5892008889729054681
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 516937508738624962}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 51b412c574066a54398b869f2e40b6ca, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::UI.Tutorial.TutorialDirector
  steps:
  - id: welcome
    message: "\uBC18\uAC00\uC6CC\uC694! \uC774 \uB3C4\uC2DC\uC758 \uC804\uB825\uC744
      \uCC45\uC784\uC9C0\uAC8C \uB41C \uB2F9\uC2E0\uC744 \uD658\uC601\uD574\uC694.\n\uBA3C\uC800
      \uAE30\uBCF8 \uC870\uC791\uC744 \uC54C\uB824\uB4DC\uB9B4\uAC8C\uC694."
    targetKind: 0
    uiTarget: {fileID: 0}
    advanceTrigger: 0
    anchor: 0
    showCondition: 0
    autoAdvanceOnDragEnded: 0
  - id: goal
    message: "\uD654\uBA74 \uC0C1\uB2E8\uC758 <b>D-Day</b>\uC640 <b>\uC77C\uC77C
      \uBAA9\uD45C \uC0DD\uC0B0\uB7C9</b>\uC744 \uD655\uC778\uD558\uC138\uC694.\nD-Day\uAC00
      \uB05D\uB098\uB294 \uB0A0\uAE4C\uC9C0 \uBAA9\uD45C\uB97C \uB2EC\uC131\uD558\uC9C0
      \uBABB\uD558\uBA74 \uAC8C\uC784 \uC624\uBC84\uC608\uC694."
    targetKind: 1
    uiTarget: {fileID: 0}
    advanceTrigger: 0
    anchor: 4
    showCondition: 0
    autoAdvanceOnDragEnded: 0
  - id: inventory
    message: "\uC67C\uCABD \uC778\uBCA4\uD1A0\uB9AC\uC5D0\uC11C \uBE14\uB7ED\uC744
      <b>\uB4DC\uB798\uADF8\uD574</b> \uD544\uB4DC\uC5D0 \uBC30\uCE58\uD574 \uBCF4\uC138\uC694."
    targetKind: 1
    uiTarget: {fileID: 0}
    advanceTrigger: 1
    anchor: 2
    showCondition: 0
    autoAdvanceOnDragEnded: 0
  - id: info_panel
    message: "\uB4DC\uB798\uADF8\uD558\uB294 \uB3D9\uC548 \uC624\uB978\uCABD \uD328\uB110\uC5D0
      <b>\uC608\uC0C1 \uBC1C\uC804\uC18C \uC2A4\uD399</b>\uC774 \uB098\uD0C0\uB098\uC694.\n\uC778\uC811\uD55C
      \uBE14\uB7ED\uC774 9\uCE78 \uC774\uC0C1, \uBD80\uD488 \uC885\uB958\uAC00 3\uC885
      \uC774\uC0C1\uC774\uBA74 \uBC1C\uC804\uC18C\uAC00 \uC644\uC131\uB3FC\uC694."
    targetKind: 1
    uiTarget: {fileID: 0}
    advanceTrigger: 0
    anchor: 1
    showCondition: 0
    autoAdvanceOnDragEnded: 1
  - id: build_first
    message: "\uC88B\uC544\uC694! \uC774\uC81C \uBE14\uB7ED\uC744 \uB354 \uC774\uC5B4
      \uBD99\uC5EC\uC11C\n<b>\uCCAB \uBC1C\uC804\uC18C</b>\uB97C \uC644\uC131\uD574
      \uBCF4\uC138\uC694."
    targetKind: 0
    uiTarget: {fileID: 0}
    advanceTrigger: 2
    anchor: 0
    showCondition: 0
    autoAdvanceOnDragEnded: 0
  - id: hover_info
    message: "\uCD95\uD558\uD574\uC694! \uC644\uC131\uB41C \uBC1C\uC804\uC18C \uC704\uC5D0
      <b>\uB9C8\uC6B0\uC2A4\uB97C \uC62C\uB824\uBCF4\uBA74</b>\n\uC624\uB978\uCABD
      \uD328\uB110\uC5D0\uC11C \uC0C1\uC138 \uC2A4\uD399\uC744 \uD655\uC778\uD560
      \uC218 \uC788\uC5B4\uC694."
    targetKind: 2
    uiTarget: {fileID: 0}
    advanceTrigger: 0
    anchor: 0
    showCondition: 0
    autoAdvanceOnDragEnded: 0
  - id: skip_ticket
    message: "\uBAA9\uD45C \uC77C\uCC28\uBCF4\uB2E4 \uC77C\uCC0D \uC77C\uC77C \uC0DD\uC0B0\uB7C9\uC744
      \uB2EC\uC131\uD558\uBA74\n<b>\uC2A4\uD0B5</b>\uC73C\uB85C \uB0A8\uC740 \uC77C\uC218\uB9CC\uD07C
      <b>\uD2F0\uCF13</b>\uC744 \uBC1B\uC744 \uC218 \uC788\uC5B4\uC694.\n\uD2F0\uCF13\uC774
      \uC313\uC774\uBA74... \uC88B\uC740 \uC77C\uC774 \uC0DD\uAE38\uC9C0\uB3C4 \uBAB0\uB77C\uC694."
    targetKind: 1
    uiTarget: {fileID: 0}
    advanceTrigger: 0
    anchor: 3
    showCondition: 1
    autoAdvanceOnDragEnded: 0
  - id: farewell
    message: "\uADF8\uB7FC \uD589\uC6B4\uC744 \uBE4C\uC5B4\uC694!"
    targetKind: 0
    uiTarget: {fileID: 0}
    advanceTrigger: 0
    anchor: 0
    showCondition: 0
    autoAdvanceOnDragEnded: 0
  dialogView: {fileID: 747903768729244707}
  highlighter: {fileID: 894878834619294852}
  completionPrefKey: Tutorial_Completed_v1
  forcePlayInEditor: 0
  devResetKey: 116
  stepTransitionDelay: 0.2
